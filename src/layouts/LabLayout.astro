---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  active?: 'home' | 'builder' | 'ev' | 'build';
}

const { title, description, active } = Astro.props;

const nav = [
  { href: '/', label: 'Home', key: 'home' },
  { href: '/builder', label: 'Builder', key: 'builder' },
  { href: '/ev', label: 'EV Breakdown', key: 'ev' },
  { href: '/build', label: 'How it works', key: 'build' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#fafafa" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <slot name="head" />
    <script src="/template-topheader.js" defer></script>
    <style>
      /* Offset page below dcrader portfolio bar (34px fixed-position) so the sticky header isn't clipped */
      html.dt-th-spaced body { padding-top: 34px; }
      html.dt-th-spaced header.sticky { top: 34px; }
    </style>
    <style>
      html { scroll-padding-top: 40px !important; }
      body { padding-top: 36px !important; }
      body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
    </style>
  </head>
  <body class="min-h-screen flex flex-col bg-lab-white text-lab-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-lab-ink focus:text-white focus:px-4 focus:py-2 focus:font-medium focus:rounded"
    >
      Skip to main content
    </a>

    <header class="thin-border-b bg-lab-white sticky top-0 z-30 backdrop-blur supports-[backdrop-filter]:bg-white/80">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-14">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="ParlayLab home">
          <span aria-hidden="true" class="inline-flex">
            <svg width="22" height="22" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
              <path d="M24 12h16v8l8 28a6 6 0 0 1-6 8H22a6 6 0 0 1-6-8l8-28z" fill="none" stroke="#0a0a0a" stroke-width="3" stroke-linejoin="round"/>
              <path d="M19 40h26a6 6 0 0 1-6 8H25a6 6 0 0 1-6-8z" fill="#7c3aed"/>
              <line x1="22" y1="12" x2="42" y2="12" stroke="#0a0a0a" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="display text-lg tracking-tight">
            Parlay<span class="text-lab-violet">Lab</span>
          </span>
        </a>
        <nav aria-label="Primary">
          <ul class="flex items-center gap-0.5 sm:gap-1">
            {nav.map((n) => (
              <li>
                <a
                  href={n.href}
                  class={`text-xs sm:text-sm px-2 sm:px-3 py-1.5 rounded-md font-medium transition-colors ${active === n.key ? 'bg-lab-violet text-white' : 'text-lab-slate hover:text-lab-ink hover:bg-lab-paper'}`}
                  aria-current={active === n.key ? 'page' : undefined}
                >
                  {n.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="thin-border-t mt-20 bg-lab-paper">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid gap-8 sm:grid-cols-3">
        <div>
          <p class="display text-2xl">Parlay<span class="text-lab-violet">Lab</span></p>
          <p class="mt-2 text-sm text-lab-slate max-w-xs">
            Stack legs, measure edge. A demo for transparent parlay math.
          </p>
        </div>
        <div>
          <p class="kpi-label">Site</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li><a class="text-lab-slate hover:text-lab-violet" href="/">Home</a></li>
            <li><a class="text-lab-slate hover:text-lab-violet" href="/builder">Builder</a></li>
            <li><a class="text-lab-slate hover:text-lab-violet" href="/ev">EV breakdown</a></li>
            <li><a class="text-lab-slate hover:text-lab-violet" href="/build">How it works</a></li>
          </ul>
        </div>
        <div>
          <p class="kpi-label">Contact</p>
          <ul class="mt-3 space-y-1.5 text-sm">
            <li>
              <a class="text-lab-slate hover:text-lab-violet" href="mailto:hello@parlaylab.dev">
                hello@parlaylab.dev
              </a>
            </li>
            <li>
              <a class="text-lab-slate hover:text-lab-violet" href="/accessibility">
                Accessibility
              </a>
            </li>
            <li class="text-lab-mute text-xs pt-2">
              &copy; {new Date().getFullYear()} ParlayLab. Built by <a class="hover:text-lab-violet underline-offset-2 hover:underline" href="https://dcrader.dev" target="_blank" rel="noopener noreferrer">Donovan Crader &middot; dcrader.dev</a>
            </li>
          </ul>
        </div>
      </div>
    </footer>

    <script>
      if (import.meta.env.DEV) {
        const audit = async () => {
          const { default: axe } = await import('axe-core');
          const startY = window.scrollY;
          const docH = document.documentElement.scrollHeight;
          const step = Math.max(200, window.innerHeight - 100);
          for (let y = 0; y < docH; y += step) {
            window.scrollTo(0, y);
            await new Promise((r) => setTimeout(r, 30));
          }
          window.scrollTo(0, startY);
          await new Promise((r) => setTimeout(r, 100));
          const results = await axe.run();
          if (results.violations.length) {
            console.group('%c axe violations', 'color:red;font-weight:bold');
            results.violations.forEach((v) => console.error(v.id, v.description, v.nodes));
            console.groupEnd();
          } else {
            console.log('%c axe: 0 violations', 'color:green;font-weight:bold');
          }
        };
        if (document.readyState === 'complete') audit();
        else window.addEventListener('load', () => setTimeout(audit, 200));
      }
    </script>
  </body>
</html>
