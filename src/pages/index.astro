---
import LabLayout from '../layouts/LabLayout.astro';
---
<LabLayout
  title="ParlayLab — Stack legs, measure edge"
  description="A demo parlay builder with implied probability and expected value calculation. Transparent sports betting math."
  active="home"
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 lab-grid pointer-events-none" aria-hidden="true"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 sm:pt-16 pb-12 sm:pb-20">
      <div class="grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <p class="eyebrow">Parlay math, made obvious</p>
          <h1 class="display text-4xl sm:text-5xl lg:text-6xl mt-3 tracking-tight">
            Stack legs,<br/>
            <span class="text-lab-violet">measure</span> edge.
          </h1>
          <p class="mt-5 text-base sm:text-lg text-lab-slate max-w-xl leading-relaxed">
            ParlayLab is a transparent parlay builder. Each leg shows you implied probability,
            the combined parlay shows true odds against the market, and the EV calculator
            tells you exactly where the edge is — or isn't.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="/builder" class="btn-primary">Try the builder
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <a href="/ev" class="btn-ghost">See an EV breakdown</a>
          </div>

          <div class="mt-10 grid grid-cols-3 gap-2 sm:gap-4 max-w-lg">
            <div class="thin-border bg-white rounded p-3">
              <p class="kpi-label">Leg 1</p>
              <p class="numeral text-lg mt-0.5">52.4%</p>
              <p class="text-[10px] text-lab-mute">implied</p>
            </div>
            <div class="thin-border bg-white rounded p-3">
              <p class="kpi-label">Leg 2</p>
              <p class="numeral text-lg mt-0.5">47.6%</p>
              <p class="text-[10px] text-lab-mute">implied</p>
            </div>
            <div class="thin-border bg-white rounded p-3">
              <p class="kpi-label">Leg 3</p>
              <p class="numeral text-lg mt-0.5">58.3%</p>
              <p class="text-[10px] text-lab-mute">implied</p>
            </div>
          </div>
        </div>

        <!-- Specimen card -->
        <div class="lg:col-span-5">
          <div class="card p-5 shadow-[0_4px_30px_-12px_rgba(124,58,237,0.18)] relative">
            <div class="flex items-center justify-between">
              <span class="tag text-lab-violet">Specimen 01</span>
              <span class="numeral text-xs text-lab-mute">PL-2026-0517</span>
            </div>
            <h2 class="display text-lg mt-3">3-Leg Parlay</h2>

            <ol class="mt-4 space-y-2.5">
              <li class="thin-border rounded bg-lab-paper px-3 py-2.5 flex items-center justify-between">
                <div>
                  <p class="text-[11px] kpi-label">NFL · Spread</p>
                  <p class="text-sm font-medium mt-0.5">Chiefs -3.5</p>
                </div>
                <p class="numeral text-sm">-110</p>
              </li>
              <li class="thin-border rounded bg-lab-paper px-3 py-2.5 flex items-center justify-between">
                <div>
                  <p class="text-[11px] kpi-label">NBA · Total</p>
                  <p class="text-sm font-medium mt-0.5">Celtics/Heat O 218.5</p>
                </div>
                <p class="numeral text-sm">+110</p>
              </li>
              <li class="thin-border rounded bg-lab-paper px-3 py-2.5 flex items-center justify-between">
                <div>
                  <p class="text-[11px] kpi-label">MLB · Player Prop</p>
                  <p class="text-sm font-medium mt-0.5">Ohtani 1+ HR</p>
                </div>
                <p class="numeral text-sm">-140</p>
              </li>
            </ol>

            <!-- Edge meter -->
            <div class="mt-5">
              <div class="flex items-center justify-between">
                <p class="kpi-label">Edge meter</p>
                <p class="numeral text-sm text-lab-violet">+4.8%</p>
              </div>
              <div class="mt-1.5 h-2 rounded-full bg-lab-paper relative overflow-hidden">
                <div class="absolute inset-y-0 left-0 bg-gradient-to-r from-lab-violet to-lab-violet-bright" style="width: 62%"></div>
                <div class="absolute inset-y-0" style="left:50%; width:1px; background:#0a0a0a; opacity:0.4"></div>
              </div>
              <div class="mt-1 flex justify-between text-[10px] text-lab-mute">
                <span>-10%</span><span>fair</span><span>+10%</span>
              </div>
            </div>

            <div class="violet-rule mt-5 pt-4 grid grid-cols-3 gap-3">
              <div>
                <p class="kpi-label">Combined</p>
                <p class="numeral text-base">+595</p>
              </div>
              <div>
                <p class="kpi-label">Stake</p>
                <p class="numeral text-base">$100</p>
              </div>
              <div>
                <p class="kpi-label">Payout</p>
                <p class="numeral text-base text-lab-violet">$695</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature triplet -->
  <section class="thin-border-t bg-lab-paper">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
      <p class="eyebrow">Method</p>
      <h2 class="display text-2xl sm:text-3xl mt-2 max-w-2xl">Three measurements every slip should carry.</h2>
      <div class="mt-8 grid sm:grid-cols-3 gap-5">
        <article class="card p-5">
          <p class="numeral text-xs text-lab-violet">01</p>
          <h3 class="display text-lg mt-2">Implied probability</h3>
          <p class="text-sm text-lab-slate mt-1.5 leading-relaxed">
            Turn moneylines into percentages. Know what the market thinks before you stack.
          </p>
        </article>
        <article class="card p-5">
          <p class="numeral text-xs text-lab-violet">02</p>
          <h3 class="display text-lg mt-2">True odds vs market</h3>
          <p class="text-sm text-lab-slate mt-1.5 leading-relaxed">
            Compare your fair line against the book. If you can't draw a difference, there's no edge.
          </p>
        </article>
        <article class="card p-5">
          <p class="numeral text-xs text-lab-violet">03</p>
          <h3 class="display text-lg mt-2">Expected value per dollar</h3>
          <p class="text-sm text-lab-slate mt-1.5 leading-relaxed">
            Convert edge into dollars. Decide stake with Kelly, not with feelings.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- Preview cards -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
    <div class="flex items-end justify-between">
      <div>
        <p class="eyebrow">Walkthroughs</p>
        <h2 class="display text-2xl sm:text-3xl mt-2">Three quick demos.</h2>
      </div>
      <p class="hidden sm:block text-sm text-lab-mute numeral">03 / 03</p>
    </div>
    <div class="mt-7 grid md:grid-cols-3 gap-5">
      <a href="/builder" class="card p-5 group hover:border-lab-violet transition-colors">
        <div class="flex items-center justify-between">
          <span class="tag text-lab-violet">Builder</span>
          <span class="numeral text-xs text-lab-mute">3 legs</span>
        </div>
        <h3 class="display text-xl mt-4">Build a slip from scratch</h3>
        <p class="text-sm text-lab-slate mt-2 leading-relaxed">
          Open three leg slots. Pick spreads, totals, and props. Watch the combined odds and implied probability calculate in real time.
        </p>
        <p class="mt-4 text-sm font-medium text-lab-violet group-hover:underline">Open the builder &rarr;</p>
      </a>
      <a href="/ev" class="card p-5 group hover:border-lab-violet transition-colors">
        <div class="flex items-center justify-between">
          <span class="tag text-lab-violet">EV Breakdown</span>
          <span class="numeral text-xs text-lab-mute">3 charts</span>
        </div>
        <h3 class="display text-xl mt-4">See where the edge is</h3>
        <p class="text-sm text-lab-slate mt-2 leading-relaxed">
          Per-leg probabilities, payout distribution, fair vs market price. Three inline charts cut the math down to plain shapes.
        </p>
        <p class="mt-4 text-sm font-medium text-lab-violet group-hover:underline">View the breakdown &rarr;</p>
      </a>
      <a href="/build" class="card p-5 group hover:border-lab-violet transition-colors">
        <div class="flex items-center justify-between">
          <span class="tag text-lab-violet">How it works</span>
          <span class="numeral text-xs text-lab-mute">4 steps</span>
        </div>
        <h3 class="display text-xl mt-4">Build your own, methodically</h3>
        <p class="text-sm text-lab-slate mt-2 leading-relaxed">
          Pick legs, check probabilities, see your edge, size the stake. A four-step protocol with a Kelly suggestion at the end.
        </p>
        <p class="mt-4 text-sm font-medium text-lab-violet group-hover:underline">Walk the protocol &rarr;</p>
      </a>
    </div>
  </section>
</LabLayout>
